# --- Database ---
POSTGRES_USER=app
POSTGRES_PASSWORD=changeme_dev_password
POSTGRES_DB=ecommerce_mini_app
POSTGRES_PORT=5432
# Full connection string the backend uses (Prisma-style). Inside Docker Compose the host
# is the service name "postgres"; if running the backend outside Docker use "localhost".
DATABASE_URL=postgresql://app:changeme_dev_password@postgres:5432/ecommerce_mini_app?schema=public

# --- Backend (NestJS) ---
BACKEND_PORT=4000
# Deliberately "development", not "production", even for the Docker Compose
# deployment: the session cookie's `secure` flag is tied to this (see
# src/main.ts), and this whole local stack runs over plain http://localhost,
# not https. Setting this to "production" would make the browser refuse to
# send the cookie back at all, breaking login. Only flip this if you also
# put HTTPS in front of the stack.
NODE_ENV=development
# Long random string used to sign the session cookie. Generate with: openssl rand -hex 32
SESSION_SECRET=changeme_generate_a_long_random_string
# Session inactivity timeout, in seconds. Spec requires 1 hour.
SESSION_INACTIVITY_TIMEOUT_SECONDS=3600
# Rate limiting on POST /auth/login
LOGIN_RATE_LIMIT_PER_IP_MAX=10
LOGIN_RATE_LIMIT_PER_IP_WINDOW_SECONDS=60
LOGIN_RATE_LIMIT_PER_ACCOUNT_MAX=5
LOGIN_RATE_LIMIT_PER_ACCOUNT_WINDOW_SECONDS=60

# --- Frontend (Next.js) ---
FRONTEND_PORT=3000
# Base URL the frontend uses to reach the backend API
NEXT_PUBLIC_API_URL=http://localhost:4000
# Origin the backend allows for CORS + cookies (must match the frontend's actual origin)
FRONTEND_ORIGIN=http://localhost:3000
# Gates the three "visible" search extras (autocomplete, highlighting, skeleton
# loading) — see README "Extras". Defaults to true (any value other than the
# literal string "false" is treated as enabled); CSRF protection is unaffected.
NEXT_PUBLIC_ENABLE_SEARCH_EXTRAS=true

# --- Seed script ---
SEED_PRODUCT_COUNT=3000
SEED_DEMO_USER_EMAIL=demo@example.com
SEED_DEMO_USER_PASSWORD=ChangeMe123!
