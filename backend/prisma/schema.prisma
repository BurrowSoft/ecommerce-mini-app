// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Session storage is handled by connect-pg-simple (its own "session" table,
// created automatically at app startup) rather than modeled here — keeps the
// session store decoupled from the Prisma-managed schema.

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  @@map("users")
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  description String
  category    String
  priceCents  Int
  // Sponsored items are regular products flagged for promotion, interleaved
  // into browse-mode results at fixed positions (5, 10, 20, 40, ... — see
  // catalog service). Excluded entirely from search results and from the
  // organic paginated query.
  isSponsored Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([category])
  @@map("products")
}
